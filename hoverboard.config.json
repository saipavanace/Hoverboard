{
  "projectName": "Hoverboard",
  "companyName": "Demo Org",
  "requirementCategories": [
    { "name": "Category1", "children": ["Sub A", "Sub B"] },
    { "name": "Category2", "children": ["Sub A", "Sub B"] },
    { "name": "Category3", "children": ["Sub A", "Sub B"] },
    { "name": "Category4", "children": ["Sub A", "Sub B"] },
    { "name": "Category5", "children": ["Sub A", "Sub B"] },
    { "name": "Category6", "children": ["Sub A", "Sub B"] },
    { "name": "Category7", "children": ["Sub A", "Sub B"] },
    { "name": "Category8", "children": ["Sub A", "Sub B"] }
  ],
  "regressionSignatureSimilarityThreshold": 0.12,
  "regressionRoots": [
    "./sample-regressions"
  ],
  "releaseMetricWeights": {
    "passRate": 0.25,
    "functionalCov": 0.2,
    "codeCov": 0.15,
    "vrCov": 0.15,
    "drClosure": 0.25
  },
  "branding": {
    "accent": "#0d9488",
    "logoUrl": null
  },
  "regressionParsers": [
    {
      "name": "fail",
      "regex": "FAIL\\b"
    },
    {
      "name": "error",
      "regex": "ERROR\\b"
    },
    {
      "name": "assert",
      "regex": "ASSERT"
    },
    {
      "name": "timeout",
      "regex": "timeout"
    },
    {
      "name": "fatal",
      "regex": "UVM_FATAL"
    }
  ],
  "coverageRegex": {
    "functional": [
      "functional\\s*coverage\\s*[:=]\\s*([0-9]+(?:\\.[0-9]+)?)\\s*%?",
      "\\bfcov\\s*[:=]\\s*([0-9]+(?:\\.[0-9]+)?)\\s*%?"
    ],
    "code": [
      "code\\s*coverage\\s*[:=]\\s*([0-9]+(?:\\.[0-9]+)?)\\s*%?",
      "\\bccov\\s*[:=]\\s*([0-9]+(?:\\.[0-9]+)?)\\s*%?"
    ]
  },
  "vrLogRegex": "(?:UVM_INFO|uvm_info|UVM_NOTE)[\\s\\S]{0,200}?\\b((?:VR|SR|CR|AR)[-_]\\d{1,8})\\b",
  "iso26262Enabled": false,
  "auth": {
    "disabled": false,
    "sessionTtlHours": 336,
    "localLoginEnabled": true,
    "localLoginDisabledInProduction": false,
    "publicAppUrl": "http://localhost:5173",
    "defaultProjectRole": "engineer",
    "syncProfileOnLogin": true,
    "allowManualProfileOverride": true,
    "linkExistingUserByEmail": true,
    "roleMappings": [],
    "builtinAdmin": {
      "email": "admin@mycompany.com",
      "username": "admin",
      "password": ""
    },
    "oidc": {
      "issuerUrl": "",
      "clientId": "",
      "clientSecret": "",
      "redirectUri": "",
      "scopes": ["openid", "profile", "email"],
      "allowedDomains": [],
      "autoCreateUsers": true,
      "groupsClaimPaths": ["groups", "realm_access.roles"]
    },
    "ldap": {
      "enabled": false,
      "url": "",
      "bindDn": "",
      "bindPassword": "",
      "searchBase": "",
      "userSearchFilter": "(uid={{username}})",
      "userAttributeList": "dn,uid,mail,cn",
      "emailAttribute": "mail",
      "displayNameAttribute": "cn",
      "departmentAttribute": "department",
      "titleAttribute": "title",
      "groupAttribute": "memberOf",
      "autoCreateUsers": true,
      "tlsRejectUnauthorized": true
    }
  }
}
